<div class="space-y-8 premium-gradient-bg min-h-screen p-4 rounded-3xl">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div>
            <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Lengkapi Profil</h1>
            <p class="text-gray-500 mt-1">Siapkan identitas properti untuk operasional harian.</p>
        </div>
    </div>

    <div class="max-w-4xl mx-auto">
        <form action="/boarding-house" method="POST"
            class="bg-white rounded-3xl shadow-xl border border-gray-100 overflow-hidden">
            <% if (typeof error !=='undefined' && error) { %>
                <div class="p-6 bg-rose-50 border-b border-rose-100 text-rose-600 font-bold flex items-center gap-3">
                    <i class="fas fa-exclamation-circle text-xl"></i>
                    <%= error %>
                </div>
                <% } %>

                    <div class="p-8 lg:p-12 space-y-8">
                        <!-- House Name & Desc -->
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                            <div class="space-y-2">
                                <label for="name"
                                    class="text-xs font-bold text-gray-400 uppercase tracking-widest px-1">Nama
                                    Kontrakan *</label>
                                <input type="text" id="name" name="name" required
                                    placeholder="Contoh: Kost Executive Ceria"
                                    class="w-full px-6 py-4 bg-gray-50 border border-transparent focus:border-primary-500 focus:bg-white rounded-2xl outline-none transition-all font-medium text-gray-900">
                            </div>
                            <div class="space-y-2">
                                <label for="email"
                                    class="text-xs font-bold text-gray-400 uppercase tracking-widest px-1">Email
                                    Korespodensi</label>
                                <input type="email" id="email" name="email" placeholder="kontak@properti.com"
                                    class="w-full px-6 py-4 bg-gray-50 border border-transparent focus:border-primary-500 focus:bg-white rounded-2xl outline-none transition-all font-medium text-gray-900">
                            </div>
                        </div>

                        <div class="space-y-2">
                            <label for="address"
                                class="text-xs font-bold text-gray-400 uppercase tracking-widest px-1">Alamat Lengkap
                                *</label>
                            <textarea id="address" name="address" required rows="2"
                                placeholder="Jl. Merdeka No. 123, Jakarta Selatan..."
                                class="w-full px-6 py-4 bg-gray-50 border border-transparent focus:border-primary-500 focus:bg-white rounded-2xl outline-none transition-all font-medium text-gray-900"></textarea>
                        </div>

                        <!-- Contact Info -->
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                            <div class="space-y-2">
                                <label for="phone"
                                    class="text-xs font-bold text-gray-400 uppercase tracking-widest px-1">No. Telepon
                                    Publik</label>
                                <div class="relative">
                                    <span class="absolute left-6 top-1/2 -translate-y-1/2 text-gray-400"><i
                                            class="fas fa-phone"></i></span>
                                    <input type="tel" id="phone" name="phone" placeholder="081234567xx"
                                        class="w-full pl-14 pr-6 py-4 bg-gray-50 border border-transparent focus:border-primary-500 focus:bg-white rounded-2xl outline-none transition-all font-medium text-gray-900">
                                </div>
                            </div>
                            <div class="space-y-2">
                                <label for="admin_wa_number"
                                    class="text-xs font-bold text-gray-400 uppercase tracking-widest px-1">Admin WA
                                    (System Manager)</label>
                                <div class="relative group">
                                    <span class="absolute left-6 top-1/2 -translate-y-1/2 text-emerald-500"><i
                                            class="fab fa-whatsapp"></i></span>
                                    <input type="text" id="admin_wa_number" name="admin_wa_number"
                                        placeholder="6281234567xx"
                                        class="w-full pl-14 pr-6 py-4 bg-emerald-50/30 border border-transparent focus:border-emerald-500 focus:bg-white rounded-2xl outline-none transition-all font-bold text-gray-900">
                                </div>
                                <p class="text-[10px] text-gray-400 mt-1 px-1">Nomor ini yang berhak mengelola tagihan
                                    via chat WhatsApp (628...).</p>
                            </div>
                        </div>

                        <div class="space-y-2">
                            <label for="description"
                                class="text-xs font-bold text-gray-400 uppercase tracking-widest px-1">Deskripsi
                                Singkat</label>
                            <textarea id="description" name="description" rows="3"
                                placeholder="Jelaskan fasilitas utama atau aturan umum..."
                                class="w-full px-6 py-4 bg-gray-50 border border-transparent focus:border-primary-500 focus:bg-white rounded-2xl outline-none transition-all font-medium text-gray-900"></textarea>
                        </div>
                    </div>

                    <div
                        class="p-8 bg-gray-50/50 border-t border-gray-100 flex flex-col md:flex-row gap-4 items-center justify-between">
                        <p class="text-sm text-gray-500 italic"><i class="fas fa-info-circle mr-1"></i> Data ini akan
                            digunakan pada seluruh kuitansi sistem.</p>
                        <div class="flex gap-4 w-full md:w-auto">
                            <a href="/boarding-house"
                                class="flex-1 md:flex-none px-8 py-4 bg-white border border-gray-200 text-gray-700 font-bold rounded-2xl hover:bg-gray-100 transition-all text-center">Batal</a>
                            <button type="submit"
                                class="flex-1 md:flex-none px-12 py-4 bg-primary-600 text-white font-extrabold rounded-2xl hover:bg-primary-700 transition-all shadow-xl shadow-primary-500/20">
                                Simpan Identitas
                            </button>
                        </div>
                    </div>
        </form>
    </div>
</div>