<div class="space-y-8 premium-gradient-bg min-h-screen p-4 rounded-3xl">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div>
            <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Kontrak Sewa</h1>
            <p class="text-gray-500 mt-1">Kelola perjanjian dan masa aktif sewa unit.</p>
        </div>
        <a href="/leases/create"
            class="btn-primary shadow-lg shadow-primary-500/20 px-6 py-3 rounded-xl transition-all hover:scale-105">
            <i class="fas fa-plus mr-2 text-sm"></i> Buat Kontrak
        </a>
    </div>

    <!-- Summary Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="room-card p-6 bg-white">
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Total Kontrak</p>
            <div class="flex items-end justify-between">
                <p class="text-3xl font-bold text-gray-900">
                    <%= leases ? leases.length : 0 %>
                </p>
                <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center text-blue-600">
                    <i class="fas fa-file-contract text-lg"></i>
                </div>
            </div>
        </div>
        <div class="room-card p-6 bg-white border-l-4 border-emerald-500">
            <p class="text-xs font-semibold text-emerald-600 uppercase tracking-wider mb-2">Sewa Aktif</p>
            <div class="flex items-end justify-between">
                <p class="text-3xl font-bold text-gray-900">
                    <%= leases ? leases.filter(l=> l.status === 'active').length : 0 %>
                </p>
                <div class="w-10 h-10 rounded-xl bg-emerald-50 flex items-center justify-center text-emerald-600">
                    <i class="fas fa-user-check text-lg"></i>
                </div>
            </div>
        </div>
        <div class="room-card p-6 bg-white border-l-4 border-gray-400">
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Selesai/History</p>
            <div class="flex items-end justify-between">
                <p class="text-3xl font-bold text-gray-900">
                    <%= leases ? leases.filter(l=> l.status !== 'active').length : 0 %>
                </p>
                <div class="w-10 h-10 rounded-xl bg-gray-50 flex items-center justify-center text-gray-400">
                    <i class="fas fa-history text-lg"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-50/50">
                        <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-wider">Unit & Penyewa
                        </th>
                        <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-wider mobile-hidden">
                            Masa Sewa</th>
                        <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-wider">Harga & Tipe</th>
                        <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-wider">Status</th>
                        <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-wider text-right">Aksi
                        </th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    <% if (leases && leases.length> 0) { %>
                        <% leases.forEach(lease=> { %>
                            <tr class="hover:bg-gray-50/50 transition-colors group">
                                <td class="px-6 py-5">
                                    <div class="flex items-center gap-3">
                                        <div
                                            class="w-10 h-10 rounded-xl bg-gray-100 flex items-center justify-center text-gray-700 font-bold group-hover:bg-primary-50 group-hover:text-primary-600 transition-all">
                                            <%= lease.room_number %>
                                        </div>
                                        <div>
                                            <p class="font-bold text-gray-900">
                                                <%= lease.tenant_name %>
                                            </p>
                                            <p class="text-xs text-gray-400">ID Kontrak #<%= lease.id %>
                                            </p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-5 mobile-hidden">
                                    <div class="text-sm font-medium text-gray-700">
                                        <%= lease.start_date %>
                                    </div>
                                    <div class="text-xs text-rose-500 font-medium italic">s/d <%= lease.due_date %>
                                    </div>
                                </td>
                                <td class="px-6 py-5">
                                    <p class="font-bold text-gray-900">Rp <%= lease.base_price.toLocaleString('id-ID')
                                            %>
                                    </p>
                                    <span
                                        class="text-[10px] uppercase font-bold px-1.5 py-0.5 rounded bg-blue-50 text-blue-600">
                                        <%= lease.rental_type==='daily' ? 'Harian' : 'Bulanan' %>
                                    </span>
                                </td>
                                <td class="px-6 py-5">
                                    <span
                                        class="status-badge <%= lease.status === 'active' ? 'status-available' : 'status-maintenance' %>">
                                        <span
                                            class="room-card-status-dot dot-<%= lease.status === 'active' ? 'available' : 'maintenance' %>"></span>
                                        <%= lease.status==='active' ? 'Aktif' : 'Selesai' %>
                                    </span>
                                </td>
                                <td class="px-6 py-5 text-right">
                                    <div class="flex justify-end gap-2">
                                        <a href="/leases/<%= lease.id %>"
                                            class="p-2.5 hover:bg-gray-100 rounded-xl text-gray-400 hover:text-primary-600 transition-all"
                                            title="Detail">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <% if (lease.status==='active' ) { %>
                                            <form action="/leases/<%= lease.id %>/checkout" method="POST" class="inline"
                                                onsubmit="return confirm('Yakin ingin checkout penyewa ini?')">
                                                <button type="submit"
                                                    class="p-2.5 bg-amber-50 text-amber-600 hover:bg-amber-100 rounded-xl transition-all"
                                                    title="Checkout">
                                                    <i class="fas fa-sign-out-alt"></i>
                                                </button>
                                            </form>
                                            <% } %>
                                                <a href="/leases/<%= lease.id %>/edit"
                                                    class="p-2.5 hover:bg-gray-100 rounded-xl text-gray-400 hover:text-amber-600 transition-all"
                                                    title="Edit">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                    </div>
                                </td>
                            </tr>
                            <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="5" class="px-6 py-20 text-center">
                                            <div
                                                class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-6">
                                                <i class="fas fa-file-contract text-gray-300 text-3xl"></i>
                                            </div>
                                            <h3 class="text-2xl font-bold text-gray-900 mb-2">Belum ada kontrak</h3>
                                            <p class="text-gray-500 mb-8 max-w-sm mx-auto">Buat kontrak sewa pertama
                                                untuk mulai menata manajemen hunian anda.</p>
                                            <a href="/leases/create"
                                                class="btn-primary px-8 py-3 rounded-xl shadow-lg shadow-primary-500/20">
                                                <i class="fas fa-plus mr-2"></i> Buat Kontrak Baru
                                            </a>
                                        </td>
                                    </tr>
                                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>