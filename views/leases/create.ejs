<div class="space-y-6">
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-800 mb-2">Buat Sewa Baru</h1>
        <p class="text-gray-600">Buat kontrak sewa untuk penyewa</p>
    </div>

    <div class="card">
        <form action="/leases" method="POST" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="form-group">
                    <label class="form-label">Pilih Kamar</label>
                    <select name="room_id" class="form-input" required>
                        <option value="">-- Pilih Kamar --</option>
                        <% if (rooms && rooms.length > 0) { %>
                            <% rooms.forEach(room => { %>
                                <option value="<%= room.id %>">Kamar <%= room.room_number %> - Rp <%= room.price_per_month.toLocaleString('id-ID') %>/bulan</option>
                            <% }); %>
                        <% } %>
                    </select>
                </div>
                
                <div class="form-group">
                    <label class="form-label">Pilih Penyewa</label>
                    <select name="tenant_id" class="form-input" required>
                        <option value="">-- Pilih Penyewa --</option>
                        <% if (tenants && tenants.length > 0) { %>
                            <% tenants.forEach(tenant => { %>
                                <option value="<%= tenant.id %>"><%= tenant.name %> - <%= tenant.whatsapp_number %></option>
                            <% }); %>
                        <% } %>
                    </select>
                </div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="form-group">
                    <label class="form-label">Tanggal Mulai</label>
                    <input type="date" name="start_date" class="form-input" required>
                </div>
                
                <div class="form-group">
                    <label class="form-label">Tanggal Berakhir</label>
                    <input type="date" name="due_date" class="form-input" required>
                </div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="form-group">
                    <label class="form-label">Tipe Sewa</label>
                    <select name="rental_type" id="rental_type" class="form-input" required>
                        <option value="monthly">Bulanan</option>
                        <option value="daily">Harian</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <label class="form-label" id="price_label">Harga Sewa (Rp)</label>
                    <input type="number" name="base_price" id="base_price" class="form-input" min="0" step="1000" required>
                    <p class="text-xs text-gray-500 mt-1" id="price_hint">Harga bulanan yang disepakati</p>
                </div>
            </div>
            
            <div class="flex space-x-4">
                <button type="submit" class="btn-primary flex-1">
                    <i class="fas fa-save mr-2"></i>
                    Buat Sewa
                </button>
                <a href="/leases" class="btn-secondary flex-1 text-center">
                    <i class="fas fa-times mr-2"></i>
                    Batal
                </a>
            </div>
        </form>
    </div>
</div>

<script>
    document.getElementById('rental_type').addEventListener('change', function() {
        const rentalType = this.value;
        const priceLabel = document.getElementById('price_label');
        const priceHint = document.getElementById('price_hint');
        
        if (rentalType === 'daily') {
            priceLabel.textContent = 'Harga Sewa Harian (Rp)';
            priceHint.textContent = 'Harga harian yang disepakati';
        } else {
            priceLabel.textContent = 'Harga Sewa (Rp)';
            priceHint.textContent = 'Harga bulanan yang disepakati';
        }
    });
</script>