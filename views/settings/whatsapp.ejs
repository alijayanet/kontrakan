<div class="space-y-8 premium-gradient-bg min-h-screen p-4 rounded-3xl">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div>
            <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">WhatsApp Gateway</h1>
            <p class="text-gray-500 mt-1">Hubungkan sistem dengan WhatsApp untuk notifikasi otomatis.</p>
        </div>
        <div id="wa-status-badge">
            <% if (waStatus.connected) { %>
                <span class="px-4 py-2 bg-emerald-100 text-emerald-700 rounded-xl font-bold flex items-center gap-2">
                    <span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></span>
                    Terhubung
                </span>
                <% } else { %>
                    <span class="px-4 py-2 bg-rose-100 text-rose-700 rounded-xl font-bold flex items-center gap-2">
                        <span class="w-2 h-2 bg-rose-500 rounded-full"></span>
                        Terputus
                    </span>
                    <% } %>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Connection Card -->
        <div class="lg:col-span-2">
            <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="p-8 border-b border-gray-50 flex justify-between items-center bg-gray-50/30">
                    <div>
                        <h2 class="text-xl font-bold text-gray-900">Scan QR Code</h2>
                        <p class="text-sm text-gray-500">Buka WhatsApp > Perangkat Tertaut > Tautkan Perangkat</p>
                    </div>
                    <% if (waStatus.connected) { %>
                        <button onclick="disconnectWA()"
                            class="px-4 py-2 bg-rose-50 text-rose-600 hover:bg-rose-100 rounded-xl font-bold transition-all">
                            Putuskan Sesi
                        </button>
                        <% } %>
                </div>

                <div class="p-12 flex flex-col items-center justify-center min-h-[400px]">
                    <div id="qr-container" class="relative group">
                        <% if (waStatus.connected) { %>
                            <div class="text-center space-y-4">
                                <div
                                    class="w-24 h-24 bg-emerald-50 text-emerald-600 rounded-full flex items-center justify-center mx-auto mb-6">
                                    <i class="fas fa-check-circle text-5xl"></i>
                                </div>
                                <h3 class="text-2xl font-bold text-gray-900">WhatsApp Aktif</h3>
                                <p class="text-gray-500 max-w-xs mx-auto text-sm">Sistem sudah siap mengirimkan
                                    notifikasi tagihan secara otomatis.</p>
                            </div>
                            <% } else if (waStatus.qr) { %>
                                <div class="p-4 bg-white border-4 border-gray-900 rounded-3xl">
                                    <div id="qrcode"></div>
                                </div>
                                <p class="mt-8 text-gray-500 font-medium animate-pulse">Menunggu pemindaian...</p>
                                <% } else { %>
                                    <div class="text-center animate-pulse">
                                        <i class="fas fa-spinner fa-spin text-4xl text-primary-500 mb-4"></i>
                                        <p class="text-gray-500">Menyiapkan QR Code...</p>
                                    </div>
                                    <% } %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Info & Instructions -->
        <div class="space-y-6">
            <div class="bg-gray-900 text-white rounded-3xl p-8 relative overflow-hidden shadow-xl shadow-gray-900/20">
                <h3 class="font-bold text-xl mb-4">Fitur Admin WA</h3>
                <ul class="space-y-4 text-sm text-gray-400">
                    <li class="flex gap-3">
                        <i class="fas fa-check-circle text-emerald-400 mt-1"></i>
                        <span>Cek tagihan tertunggak via WA dengan perintah *tagihan*</span>
                    </li>
                    <li class="flex gap-3">
                        <i class="fas fa-check-circle text-emerald-400 mt-1"></i>
                        <span>Lunasi tagihan penyewa langsung via WA: *bayar [id_tagihan]*</span>
                    </li>
                    <li class="flex gap-3">
                        <i class="fas fa-check-circle text-emerald-400 mt-1"></i>
                        <span>Notifikasi otomatis H-3 sebelum jatuh tempo.</span>
                    </li>
                </ul>
            </div>

            <div class="bg-white rounded-3xl p-8 border border-gray-100 shadow-sm">
                <h3 class="font-bold text-gray-900 mb-4">Test Pengiriman</h3>
                <form id="test-wa-form" class="space-y-4">
                    <div>
                        <label class="block text-xs font-bold text-gray-400 uppercase mb-2">Nomor WhatsApp</label>
                        <input type="text" id="test-phone" placeholder="62812345678"
                            class="w-full px-4 py-3 bg-gray-50 border border-gray-100 rounded-xl text-sm focus:ring-2 focus:ring-primary-500 outline-none">
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-400 uppercase mb-2">Pesan</label>
                        <textarea id="test-message"
                            class="w-full px-4 py-3 bg-gray-50 border border-gray-100 rounded-xl text-sm focus:ring-2 focus:ring-primary-500 outline-none h-24">Halo, ini pesan percobaan dari Kost Manager.</textarea>
                    </div>
                    <button type="submit"
                        class="w-full bg-primary-600 hover:bg-primary-700 text-white font-bold py-3 rounded-xl transition-all shadow-lg shadow-primary-500/20 text-sm">
                        Kirim Pesan Test
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script>
    const qrText = "<%= waStatus.qr || '' %>";
    if (qrText && document.getElementById('qrcode')) {
        new QRCode(document.getElementById("qrcode"), {
            text: qrText,
            width: 256,
            height: 256,
            colorDark: "#000000",
            colorLight: "#ffffff",
            correctLevel: QRCode.CorrectLevel.H
        });
    }

    // Auto refresh status every 5 seconds
    setInterval(async () => {
        try {
            const res = await fetch('/settings/whatsapp/status');
            const data = await res.json();

            // If status changed or new QR arrives, reload page
            const isConnected = "<%= waStatus.connected %>" === "true";
            if (data.connected !== isConnected || (data.qr && !qrText)) {
                window.location.reload();
            }
        } catch (e) {
            console.error("Failed to fetch WA status", e);
        }
    }, 5000);

    async function disconnectWA() {
        if (!confirm('Apakah anda yakin ingin memutuskan sesi WhatsApp?')) return;

        const res = await fetch('/settings/whatsapp/disconnect', { method: 'POST' });
        const data = await res.json();
        if (data.success) {
            window.location.reload();
        }
    }

    document.getElementById('test-wa-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const phone = document.getElementById('test-phone').value;
        const message = document.getElementById('test-message').value;

        const res = await fetch('/settings/whatsapp/test', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ phone, message })
        });
        const data = await res.json();
        if (data.success) {
            alert('Pesan berhasil dikirim!');
        } else {
            alert('Gagal mengirim pesan: ' + data.message);
        }
    });
</script>