<div class="space-y-6">
    <div class="flex justify-between items-center">
        <h1 class="text-2xl font-bold text-gray-800">Tagihan Belum Bayar</h1>
        <div class="flex space-x-3">
            <a href="/invoices" class="btn-secondary">
                <i class="fas fa-arrow-left mr-2"></i>
                Kembali ke Semua Tagihan
            </a>
        </div>
    </div>

    <% if (invoices && invoices.length > 0) { %>
        <div class="grid gap-6">
            <% invoices.forEach(invoice => { %>
                <div class="card">
                    <div class="flex justify-between items-start mb-4">
                        <div>
                            <h3 class="text-lg font-medium text-gray-900">Kamar <%= invoice.room_number %></h3>
                            <p class="text-sm text-gray-600"><%= invoice.tenant_name %></p>
                        </div>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                            Belum Bayar
                        </span>
                    </div>
                    
                    <div class="space-y-2 mb-4">
                        <div class="flex justify-between">
                            <span class="text-sm text-gray-600">Nomor Tagihan</span>
                            <span class="text-sm font-medium">#<%= invoice.id %></span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-sm text-gray-600">Tanggal</span>
                            <span class="text-sm font-medium"><%= invoice.due_date %></span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-sm text-gray-600">Jatuh Tempo</span>
                            <span class="text-sm font-medium <%= new Date(invoice.due_date) < new Date() ? 'text-red-600' : '' %>"><%= invoice.due_date %></span>
                        </div>
                        <% const totalAmount = invoice.amount + (invoice.extra_charges || 0); %>
                        <div class="flex justify-between">
                            <span class="text-sm text-gray-600">Total</span>
                            <span class="text-sm font-medium">Rp <%= totalAmount.toLocaleString('id-ID') %></span>
                        </div>
                    </div>
                    
                    <div class="flex space-x-2">
                        <a href="/invoices/<%= invoice.id %>" class="btn-secondary text-xs">
                            <i class="fas fa-eye mr-1"></i>
                            Detail
                        </a>
                        <% const totalAmount = invoice.amount + (invoice.extra_charges || 0); %>
                        <button onclick="sendWhatsApp('<%= invoice.whatsapp_number %>', '<%= invoice.tenant_name %>', '<%= invoice.id %>', '<%= totalAmount %>')" class="btn-success text-xs">
                            <i class="fab fa-whatsapp mr-1"></i>
                            WhatsApp
                        </button>
                    </div>
                </div>
            <% }); %>
        </div>
    <% } else { %>
        <div class="card text-center py-12">
            <i class="fas fa-check-circle text-6xl text-green-500 mb-4"></i>
            <h3 class="text-lg font-medium text-gray-900 mb-2">Tidak Ada Tagihan Belum Bayar</h3>
            <p class="text-gray-600">Semua tagihan sudah dibayar atau belum ada tagihan yang dibuat.</p>
        </div>
    <% } %>
</div>

<script>
function sendWhatsApp(phone, name, invoiceId, amount) {
    if (confirm(`Kirim reminder pembayaran ke ${name} (${phone})?`)) {
        const message = `Halo, Kak ${name}!\n\nIni reminder untuk pembayaran tagihan #${invoiceId} sebesar Rp ${parseFloat(amount).toLocaleString('id-ID')}.\n\nSilakan lakukan pembayaran sebelum jatuh tempo. Terima kasih!`;
        window.open(`https://wa.me/${phone.replace(/[^0-9]/g, '')}?text=${encodeURIComponent(message)}`, '_blank');
    }
}
</script>