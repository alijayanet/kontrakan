<div class="space-y-8 premium-gradient-bg min-h-screen p-4 rounded-3xl">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div>
            <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Manajemen Penyewa</h1>
            <p class="text-gray-500 mt-1">Daftar semua penghuni aktif dan riwayat penyewa.</p>
        </div>
        <a href="/tenants/create"
            class="btn-primary shadow-lg shadow-primary-500/20 px-6 py-3 rounded-xl transition-all hover:scale-105">
            <i class="fas fa-plus mr-2 text-sm"></i>
            Tambah Penyewa
        </a>
    </div>

    <!-- Summary Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <div class="room-card p-6 bg-white">
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Total Penyewa</p>
            <div class="flex items-end justify-between">
                <p class="text-3xl font-bold text-gray-900">
                    <%= tenants ? tenants.length : 0 %>
                </p>
                <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center text-blue-600">
                    <i class="fas fa-users text-lg"></i>
                </div>
            </div>
        </div>
        <div class="room-card p-6 bg-white border-l-4 border-emerald-500">
            <p class="text-xs font-semibold text-emerald-600 uppercase tracking-wider mb-2">Penyewa Aktif</p>
            <div class="flex items-end justify-between">
                <p class="text-3xl font-bold text-gray-900">
                    <%= tenants ? tenants.filter(t=> t.status !== 'inactive').length : 0 %>
                </p>
                <div class="w-10 h-10 rounded-xl bg-emerald-50 flex items-center justify-center text-emerald-600">
                    <i class="fas fa-user-check text-lg"></i>
                </div>
            </div>
        </div>
        <div class="room-card p-6 bg-white border-l-4 border-rose-500">
            <p class="text-xs font-semibold text-rose-600 uppercase tracking-wider mb-2">Butuh Perhatian</p>
            <div class="flex items-end justify-between">
                <p class="text-3xl font-bold text-gray-900">0</p>
                <div class="w-10 h-10 rounded-xl bg-rose-50 flex items-center justify-center text-rose-600">
                    <i class="fas fa-exclamation-circle text-lg"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-50/50">
                        <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-wider">Nama & Identitas
                        </th>
                        <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-wider mobile-hidden">No
                            WhatsApp</th>
                        <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-wider mobile-hidden">
                            Kontak Darurat</th>
                        <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-wider">Status</th>
                        <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-wider text-right">Aksi
                        </th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    <% if (tenants && tenants.length> 0) { %>
                        <% tenants.forEach(tenant=> { %>
                            <tr class="hover:bg-gray-50/50 transition-colors group">
                                <td class="px-6 py-5">
                                    <div class="flex items-center gap-3">
                                        <div
                                            class="w-10 h-10 rounded-full bg-primary-50 flex items-center justify-center text-primary-600 font-bold group-hover:scale-110 transition-all">
                                            <%= tenant.name.charAt(0) %>
                                        </div>
                                        <div>
                                            <p class="font-bold text-gray-900">
                                                <%= tenant.name %>
                                            </p>
                                            <p class="text-xs text-gray-400">ID: <%= tenant.identity_number || '-' %>
                                            </p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-5 mobile-hidden">
                                    <a href="https://wa.me/<%= tenant.whatsapp_number %>" target="_blank"
                                        class="inline-flex items-center gap-2 text-emerald-600 hover:text-emerald-700 font-medium whitespace-nowrap">
                                        <i class="fab fa-whatsapp"></i>
                                        <%= tenant.whatsapp_number %>
                                    </a>
                                </td>
                                <td class="px-6 py-5 mobile-hidden text-sm text-gray-600">
                                    <%= tenant.emergency_contact || '-' %>
                                </td>
                                <td class="px-6 py-5">
                                    <span
                                        class="status-badge <%= tenant.status === 'inactive' ? 'status-maintenance' : 'status-available' %>">
                                        <span
                                            class="room-card-status-dot dot-<%= tenant.status === 'inactive' ? 'maintenance' : 'available' %>"></span>
                                        <%= tenant.status==='inactive' ? 'Nonaktif' : 'Aktif' %>
                                    </span>
                                </td>
                                <td class="px-6 py-5 text-right">
                                    <div class="flex justify-end gap-2">
                                        <a href="/tenants/<%= tenant.id %>"
                                            class="p-2 hover:bg-white border border-transparent hover:border-gray-200 rounded-xl text-gray-400 hover:text-primary-600 transition-all"
                                            title="Detail">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="/tenants/<%= tenant.id %>/edit"
                                            class="p-2 hover:bg-white border border-transparent hover:border-gray-200 rounded-xl text-gray-400 hover:text-amber-600 transition-all"
                                            title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form action="/tenants/<%= tenant.id %>?_method=DELETE" method="POST"
                                            class="inline"
                                            onsubmit="return confirm('Yakin ingin menghapus penyewa ini?')">
                                            <button type="submit"
                                                class="p-2 hover:bg-white border border-transparent hover:border-gray-200 rounded-xl text-gray-400 hover:text-rose-600 transition-all"
                                                title="Hapus">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="5" class="px-6 py-20 text-center">
                                            <div
                                                class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-6">
                                                <i class="fas fa-users text-gray-300 text-3xl"></i>
                                            </div>
                                            <h3 class="text-2xl font-bold text-gray-900 mb-2">Belum ada penyewa</h3>
                                            <p class="text-gray-500 mb-8 max-w-sm mx-auto">Tambahkan penyewa untuk
                                                memulai manajemen operasional kost anda.</p>
                                            <a href="/tenants/create"
                                                class="btn-primary px-8 py-3 rounded-xl shadow-lg shadow-primary-500/20">
                                                <i class="fas fa-plus mr-2"></i>
                                                Tambah Penyewa Sekarang
                                            </a>
                                        </td>
                                    </tr>
                                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>