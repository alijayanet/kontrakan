<div class="space-y-6">
    <div class="flex justify-between items-center">
        <h1 class="text-2xl font-bold text-gray-800">Edit Penyewa</h1>
        <a href="/tenants" class="btn-secondary">
            <i class="fas fa-arrow-left mr-2"></i>
            Kembali ke Penyewa
        </a>
    </div>

    <form action="/tenants/<%= tenant.id %>?_method=PUT" method="POST" class="card">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="form-group">
                <label for="name" class="form-label">Nama Lengkap</label>
                <input type="text" name="name" id="name" value="<%= tenant.name %>" class="form-input" required>
            </div>

            <div class="form-group">
                <label for="whatsapp_number" class="form-label">Nomor WhatsApp</label>
                <input type="text" name="whatsapp_number" id="whatsapp_number" value="<%= tenant.whatsapp_number %>" class="form-input" required>
            </div>

            <div class="form-group">
                <label for="email" class="form-label">Email</label>
                <input type="email" name="email" id="email" value="<%= tenant.email || '' %>" class="form-input">
            </div>

            <div class="form-group">
                <label for="emergency_contact" class="form-label">Kontak Darurat</label>
                <input type="text" name="emergency_contact" id="emergency_contact" value="<%= tenant.emergency_contact || '' %>" class="form-input">
            </div>

            <div class="form-group md:col-span-2">
                <label for="address" class="form-label">Alamat</label>
                <textarea name="address" id="address" rows="3" class="form-input"><%= tenant.address || '' %></textarea>
            </div>

            <div class="form-group md:col-span-2">
                <label for="notes" class="form-label">Catatan</label>
                <textarea name="notes" id="notes" rows="2" class="form-input"><%= tenant.notes || '' %></textarea>
            </div>
        </div>

        <div class="flex justify-end space-x-3 mt-6">
            <button type="submit" class="btn-primary">
                <i class="fas fa-save mr-2"></i>
                Update Penyewa
            </button>
            <a href="/tenants" class="btn-secondary">Batal</a>
        </div>
    </form>
</div>