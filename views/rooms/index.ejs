<div class="space-y-8 premium-gradient-bg min-h-screen p-4 rounded-3xl">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div>
            <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Data Kamar</h1>
            <p class="text-gray-500 mt-1">Kelola semua unit kamar anda dalam satu tampilan.</p>
        </div>
        <a href="/rooms/create"
            class="btn-primary shadow-lg shadow-primary-500/20 px-6 py-3 rounded-xl transition-all hover:scale-105">
            <i class="fas fa-plus mr-2 text-sm"></i>
            Tambah Kamar Baru
        </a>
    </div>

    <!-- Stats Overview (Symmetrical) -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <% const stats={ total: rooms.length, available: rooms.filter(r=> r.status === 'available').length,
            occupied: rooms.filter(r => r.status === 'occupied').length,
            maintenance: rooms.filter(r => r.status === 'maintenance').length
            }
            %>
            <div class="bg-white p-4 rounded-2xl border border-gray-100 shadow-sm">
                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Total Unit</p>
                <p class="text-2xl font-bold text-gray-900">
                    <%= stats.total %>
                </p>
            </div>
            <div class="bg-white p-4 rounded-2xl border border-gray-100 shadow-sm">
                <p class="text-xs font-semibold text-emerald-500 uppercase tracking-wider">Tersedia</p>
                <p class="text-2xl font-bold text-gray-900">
                    <%= stats.available %>
                </p>
            </div>
            <div class="bg-white p-4 rounded-2xl border border-gray-100 shadow-sm">
                <p class="text-xs font-semibold text-rose-500 uppercase tracking-wider">Terisi</p>
                <p class="text-2xl font-bold text-gray-900">
                    <%= stats.occupied %>
                </p>
            </div>
            <div class="bg-white p-4 rounded-2xl border border-gray-100 shadow-sm">
                <p class="text-xs font-semibold text-amber-500 uppercase tracking-wider">Maintenance</p>
                <p class="text-2xl font-bold text-gray-900">
                    <%= stats.maintenance %>
                </p>
            </div>
    </div>

    <!-- Room Cards Grid - strictly 4 columns on large screens -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <% if (rooms && rooms.length> 0) { %>
            <% rooms.forEach(room=> { %>
                <div class="room-card group">
                    <div class="p-0">
                        <!-- Card Header/Image Placeholder -->
                        <div class="h-32 bg-gray-100 relative overflow-hidden">
                            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent z-10"></div>
                            <div class="absolute bottom-4 left-4 z-20">
                                <span class="text-white font-bold text-xl">#<%= room.room_number %></span>
                                <p class="text-gray-200 text-xs font-medium">
                                    <%= room.type || 'Regular Unit' %>
                                </p>
                            </div>
                            <div class="absolute top-4 right-4 z-20">
                                <span class="status-badge <%= 
                                    room.status === 'available' ? 'status-available' : 
                                    room.status === 'occupied' ? 'status-occupied' : 
                                    room.status === 'maintenance' ? 'status-maintenance' : 'status-booking' 
                                %>">
                                    <span class="room-card-status-dot dot-<%= room.status %>"></span>
                                    <%= room.status==='available' ? 'Tersedia' : room.status==='occupied' ? 'Terisi' :
                                        room.status==='maintenance' ? 'Maintenance' : 'Booking' %>
                                </span>
                            </div>
                        </div>

                        <div class="p-6">
                            <div class="flex items-center justify-between mb-4">
                                <div class="text-primary-600 font-bold text-lg">
                                    Rp <%= room.price_per_month.toLocaleString('id-ID') %>
                                        <span class="text-gray-400 text-xs font-normal">/ bulan</span>
                                </div>
                            </div>

                            <p class="text-sm text-gray-500 line-clamp-2 mb-6 h-10">
                                <%= room.description || 'Tidak ada deskripsi tambahan untuk unit ini.' %>
                            </p>

                            <div class="flex items-center gap-2">
                                <a href="/rooms/<%= room.id %>"
                                    class="flex-1 bg-gray-50 hover:bg-gray-100 text-gray-700 font-semibold py-2.5 rounded-xl text-center text-sm transition-all">
                                    Detail
                                </a>
                                <div class="flex gap-1">
                                    <a href="/rooms/<%= room.id %>/edit"
                                        class="p-2.5 bg-amber-50 text-amber-600 hover:bg-amber-100 rounded-xl transition-all"
                                        title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form action="/rooms/<%= room.id %>?_method=DELETE" method="POST"
                                        onsubmit="return confirm('Yakin ingin menghapus kamar ini?')">
                                        <button type="submit"
                                            class="p-2.5 bg-rose-50 text-rose-600 hover:bg-rose-100 rounded-xl transition-all"
                                            title="Hapus">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <% }); %>
                    <% } else { %>
                        <div class="col-span-full">
                            <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-16 text-center">
                                <div
                                    class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-6">
                                    <i class="fas fa-door-open text-gray-300 text-3xl"></i>
                                </div>
                                <h3 class="text-2xl font-bold text-gray-900 mb-2">Belum ada unit tersedia</h3>
                                <p class="text-gray-500 mb-8 max-w-md mx-auto">Mulai kelola bisnis kost anda dengan
                                    menambahkan unit kamar pertama anda.</p>
                                <a href="/rooms/create"
                                    class="btn-primary px-8 py-3 rounded-xl shadow-lg shadow-primary-500/20">
                                    <i class="fas fa-plus mr-2"></i>
                                    Tambah Unit Sekarang
                                </a>
                            </div>
                        </div>
                        <% } %>
    </div>
</div>