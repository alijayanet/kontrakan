<div class="space-y-8 premium-gradient-bg min-h-screen p-4 rounded-3xl">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div>
            <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Catatan Pengeluaran</h1>
            <p class="text-gray-500 mt-1">Pantau arus kas keluar dan biaya operasional properti Anda.</p>
        </div>
        <button onclick="toggleModal('expenseModal')"
            class="px-8 py-4 bg-primary-600 text-white font-extrabold rounded-2xl hover:bg-primary-700 transition-all shadow-xl shadow-primary-500/20 flex items-center gap-2">
            <i class="fas fa-plus-circle"></i> Catat Biaya Baru
        </button>
    </div>

    <!-- Summary Stats -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white p-8 rounded-3xl shadow-sm border border-gray-100 relative overflow-hidden group">
            <div
                class="absolute -right-4 -bottom-4 text-emerald-50 opacity-10 group-hover:scale-110 transition-transform">
                <i class="fas fa-wallet text-9xl"></i>
            </div>
            <p class="text-sm font-bold text-gray-400 uppercase tracking-widest mb-1">Total Biaya (Semua)</p>
            <h2 class="text-3xl font-black text-gray-900">Rp <%= total.toLocaleString('id-ID') %>
            </h2>
        </div>

        <div class="bg-white p-8 rounded-3xl shadow-sm border border-gray-100 relative overflow-hidden group">
            <div
                class="absolute -right-4 -bottom-4 text-primary-50 opacity-10 group-hover:scale-110 transition-transform">
                <i class="fas fa-tags text-9xl"></i>
            </div>
            <p class="text-sm font-bold text-gray-400 uppercase tracking-widest mb-1">Total Transaksi</p>
            <h2 class="text-3xl font-black text-gray-900">
                <%= expenses.length %>
            </h2>
        </div>
    </div>

    <!-- Expense List Table -->
    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-50 border-b border-gray-100">
                        <th class="px-8 py-6 text-xs font-bold text-gray-400 uppercase tracking-widest">Tanggal</th>
                        <th class="px-8 py-6 text-xs font-bold text-gray-400 uppercase tracking-widest">Kategori</th>
                        <th class="px-8 py-6 text-xs font-bold text-gray-400 uppercase tracking-widest">Keterangan</th>
                        <th class="px-8 py-6 text-xs font-bold text-gray-400 uppercase tracking-widest">Jumlah</th>
                        <th class="px-8 py-6 text-xs font-bold text-gray-400 uppercase tracking-widest text-center">Aksi
                        </th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    <% if (expenses && expenses.length> 0) { %>
                        <% expenses.forEach(expense=> { %>
                            <tr class="hover:bg-gray-50/50 transition-all">
                                <td class="px-8 py-6 text-gray-900 font-bold">
                                    <%= moment(expense.date).format('DD MMM YYYY') %>
                                </td>
                                <td class="px-8 py-6">
                                    <span
                                        class="px-4 py-1.5 bg-gray-100 text-gray-600 rounded-full text-xs font-bold uppercase tracking-widest">
                                        <%= expense.category %>
                                    </span>
                                </td>
                                <td class="px-8 py-6 text-gray-500">
                                    <%= expense.description || '-' %>
                                </td>
                                <td class="px-8 py-6 text-rose-600 font-black">- Rp <%=
                                        expense.amount.toLocaleString('id-ID') %>
                                </td>
                                <td class="px-8 py-6 text-center">
                                    <button onclick="deleteExpense('<%= expense.id %>')"
                                        class="w-10 h-10 inline-flex items-center justify-center rounded-xl bg-rose-50 text-rose-600 hover:bg-rose-600 hover:text-white transition-all">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </td>
                            </tr>
                            <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="5" class="px-8 py-20 text-center text-gray-400">
                                            <i class="fas fa-receipt text-6xl mb-4 block opacity-20"></i>
                                            <p class="text-lg font-bold">Belum ada catatan pengeluaran.</p>
                                            <p class="text-sm">Klik tombol "Catat Biaya Baru" untuk memulai.</p>
                                        </td>
                                    </tr>
                                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Create Expense -->
<div id="expenseModal" class="fixed inset-0 z-50 hidden overflow-y-auto">
    <div class="fixed inset-0 bg-gray-900/60 backdrop-blur-sm transition-opacity" onclick="toggleModal('expenseModal')">
    </div>
    <div class="flex min-h-screen items-center justify-center p-4">
        <div class="relative w-full max-w-xl bg-white rounded-3xl shadow-2xl overflow-hidden border border-gray-100">
            <div class="px-8 py-8 border-b border-gray-50">
                <h3 class="text-2xl font-black text-gray-900 flex items-center gap-3">
                    <i class="fas fa-wallet text-emerald-500"></i> Catat Biaya Baru
                </h3>
            </div>

            <form action="/expenses" method="POST" class="p-8 space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-2">
                        <label for="date" class="text-xs font-bold text-gray-400 uppercase tracking-widest px-1">Tanggal
                            *</label>
                        <input type="date" id="date" name="date" required
                            value="<%= new Date().toISOString().split('T')[0] %>"
                            class="w-full px-5 py-4 bg-gray-50 border border-transparent focus:border-primary-500 focus:bg-white rounded-2xl outline-none transition-all font-medium text-gray-900">
                    </div>
                    <div class="space-y-2">
                        <label for="category"
                            class="text-xs font-bold text-gray-400 uppercase tracking-widest px-1">Kategori
                            *</label>
                        <select id="category" name="category" required
                            class="w-full px-5 py-4 bg-gray-50 border border-transparent focus:border-primary-500 focus:bg-white rounded-2xl outline-none transition-all font-medium text-gray-900">
                            <option value="Listrik/PLN">Listrik/PLN</option>
                            <option value="Air/PDAM">Air/PDAM</option>
                            <option value="Maintenance">Maintenance/Perbaikan</option>
                            <option value="Kebersihan">Kebersihan & Keamanan</option>
                            <option value="Lainnya">Lainnya</option>
                        </select>
                    </div>
                </div>

                <div class="space-y-2">
                    <label for="amount" class="text-xs font-bold text-gray-400 uppercase tracking-widest px-1">Jumlah
                        (Rp) *</label>
                    <div class="relative">
                        <span class="absolute left-6 top-1/2 -translate-y-1/2 text-gray-400 font-bold">Rp</span>
                        <input type="number" id="amount" name="amount" required placeholder="0"
                            class="w-full pl-14 pr-6 py-4 bg-gray-50 border border-transparent focus:border-primary-500 focus:bg-white rounded-2xl outline-none transition-all font-black text-gray-900">
                    </div>
                </div>

                <div class="space-y-2">
                    <label for="description"
                        class="text-xs font-bold text-gray-400 uppercase tracking-widest px-1">Keterangan
                        Tambahan</label>
                    <textarea id="description" name="description" rows="3"
                        placeholder="Misal: Beli token listrik atau servis pompa air..."
                        class="w-full px-5 py-4 bg-gray-50 border border-transparent focus:border-primary-500 focus:bg-white rounded-2xl outline-none transition-all font-medium text-gray-900"></textarea>
                </div>

                <div class="flex gap-4 pt-4">
                    <button type="button" onclick="toggleModal('expenseModal')"
                        class="flex-1 py-4 bg-gray-100 text-gray-700 font-bold rounded-2xl hover:bg-gray-200 transition-all text-center">Batal</button>
                    <button type="submit"
                        class="flex-1 py-4 bg-emerald-600 text-white font-extrabold rounded-2xl hover:bg-emerald-700 transition-all shadow-xl shadow-emerald-500/20">
                        Simpan Biaya
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function toggleModal(id) {
        const modal = document.getElementById(id);
        if (modal) {
            modal.classList.toggle('hidden');
        }
    }

    async function deleteExpense(id) {
        if (confirm('Apakah Anda yakin ingin menghapus catatan pengeluaran ini?')) {
            try {
                const response = await fetch('/expenses/' + id, {
                    method: 'DELETE'
                });
                const result = await response.json();
                if (result.success) {
                    window.location.reload();
                } else {
                    alert(result.message || 'Gagal menghapus data');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Terjadi kesalahan saat menghapus data');
            }
        }
    }
</script>