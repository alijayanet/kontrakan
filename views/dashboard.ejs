<div class="space-y-8 premium-gradient-bg min-h-screen p-4 rounded-3xl">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div>
            <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Dashboard Overview</h1>
            <p class="text-gray-500 mt-1">Status terkini operasional kontrakan anda.</p>
        </div>
        <div class="flex gap-2">
            <a href="/invoices/create"
                class="bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-2.5 px-6 rounded-xl transition-all shadow-lg shadow-emerald-500/20 text-sm">
                <i class="fas fa-plus mr-2"></i> Buat Tagihan
            </a>
            <a href="/leases/create"
                class="bg-primary-600 hover:bg-primary-700 text-white font-semibold py-2.5 px-6 rounded-xl transition-all shadow-lg shadow-primary-500/20 text-sm">
                <i class="fas fa-user-plus mr-2"></i> Sewa Baru
            </a>
        </div>
    </div>

    <!-- Statistic Cards (Symmetrical 4-column) -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Total Rooms -->
        <div class="room-card p-6 bg-white flex items-center gap-4">
            <div class="w-14 h-14 rounded-2xl bg-blue-50 flex items-center justify-center text-blue-600">
                <i class="fas fa-door-open text-2xl"></i>
            </div>
            <div>
                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Total Unit</p>
                <p class="text-2xl font-bold text-gray-900">
                    <%= roomStats.total_rooms %>
                </p>
            </div>
        </div>

        <!-- Available Rooms -->
        <div class="room-card p-6 bg-white flex items-center gap-4">
            <div class="w-14 h-14 rounded-2xl bg-emerald-50 flex items-center justify-center text-emerald-600">
                <i class="fas fa-check-circle text-2xl"></i>
            </div>
            <div>
                <p class="text-xs font-semibold text-emerald-500 uppercase tracking-wider">Tersedia</p>
                <p class="text-2xl font-bold text-gray-900">
                    <%= roomStats.available_rooms %>
                </p>
            </div>
        </div>

        <!-- Occupied Rooms -->
        <div class="room-card p-6 bg-white flex items-center gap-4">
            <div class="w-14 h-14 rounded-2xl bg-rose-50 flex items-center justify-center text-rose-600">
                <i class="fas fa-user-check text-2xl"></i>
            </div>
            <div>
                <p class="text-xs font-semibold text-rose-500 uppercase tracking-wider">Terisi</p>
                <p class="text-2xl font-bold text-gray-900">
                    <%= roomStats.occupied_rooms %>
                </p>
            </div>
        </div>

        <!-- Revenue -->
        <div class="room-card p-6 bg-emerald-600 text-white flex items-center gap-4">
            <div class="w-14 h-14 rounded-2xl bg-white/20 flex items-center justify-center text-white">
                <i class="fas fa-wallet text-2xl"></i>
            </div>
            <div>
                <p class="text-xs font-semibold text-emerald-100 uppercase tracking-wider">Pendapatan</p>
                <p class="text-xl font-bold">Rp <%= (invoiceStats.total_received || 0).toLocaleString('id-ID') %>
                </p>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Recent Occupancy -->
        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="p-6 border-b border-gray-50 flex justify-between items-center bg-gray-50/50">
                <h3 class="font-bold text-gray-900 flex items-center gap-2">
                    <i class="fas fa-users text-blue-500"></i>
                    Penghuni Saat Ini
                </h3>
                <a href="/rooms" class="text-xs font-semibold text-primary-600 hover:text-primary-700">Lihat Semua</a>
            </div>
            <div class="p-2">
                <% if (occupiedRooms && occupiedRooms.length> 0) { %>
                    <div class="space-y-1">
                        <% occupiedRooms.forEach(room=> { %>
                            <div
                                class="flex items-center justify-between p-4 hover:bg-gray-50 rounded-2xl transition-all group">
                                <div class="flex items-center gap-4">
                                    <div
                                        class="w-12 h-12 rounded-xl bg-gray-100 flex items-center justify-center font-bold text-gray-700 group-hover:bg-primary-50 group-hover:text-primary-600 transition-all">
                                        <%= room.room_number %>
                                    </div>
                                    <div>
                                        <p class="font-bold text-gray-900">
                                            <%= room.tenant_name %>
                                        </p>
                                        <p class="text-xs text-gray-500">Unit Terisi Aktif</p>
                                    </div>
                                </div>
                                <span class="status-badge status-occupied">Terisi</span>
                            </div>
                            <% }); %>
                    </div>
                    <% } else { %>
                        <div class="py-12 text-center">
                            <i class="fas fa-user-slash text-gray-200 text-4xl mb-3"></i>
                            <p class="text-gray-500 text-sm">Belum ada kamar yang terisi</p>
                        </div>
                        <% } %>
            </div>
        </div>

        <!-- Expiring Leases -->
        <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="p-6 border-b border-gray-50 flex justify-between items-center bg-gray-50/50">
                <h3 class="font-bold text-gray-900 flex items-center gap-2">
                    <i class="fas fa-clock text-amber-500"></i>
                    Sewa Akan Berakhir
                </h3>
                <span class="text-xs px-2 py-1 bg-amber-50 text-amber-600 rounded-lg">7 Hari Kedepan</span>
            </div>
            <div class="p-2">
                <% if (expiringLeases && expiringLeases.length> 0) { %>
                    <div class="space-y-1">
                        <% expiringLeases.forEach(lease=> { %>
                            <div
                                class="flex items-center justify-between p-4 hover:bg-rose-50/30 rounded-2xl transition-all group">
                                <div class="flex items-center gap-4">
                                    <div
                                        class="w-12 h-12 rounded-xl bg-amber-50 flex items-center justify-center font-bold text-amber-600 group-hover:bg-amber-100 transition-all">
                                        <%= lease.room_number %>
                                    </div>
                                    <div>
                                        <p class="font-bold text-gray-900">
                                            <%= lease.tenant_name %>
                                        </p>
                                        <p class="text-xs text-rose-500 font-medium">Berakhir: <%= lease.due_date %>
                                        </p>
                                    </div>
                                </div>
                                <a href="/leases/<%= lease.id %>"
                                    class="p-2 hover:bg-white rounded-xl text-gray-400 hover:text-primary-600 transition-all">
                                    <i class="fas fa-chevron-right"></i>
                                </a>
                            </div>
                            <% }); %>
                    </div>
                    <% } else { %>
                        <div class="py-12 text-center">
                            <i class="fas fa-calendar-check text-gray-200 text-4xl mb-3"></i>
                            <p class="text-gray-500 text-sm">Semua kontrak masih aman</p>
                        </div>
                        <% } %>
            </div>
        </div>
    </div>
</div>