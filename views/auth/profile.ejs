<div class="space-y-8 premium-gradient-bg min-h-screen p-4 rounded-3xl">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div>
            <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Pengaturan Akun</h1>
            <p class="text-gray-500 mt-1">Kelola kredensial login dan profil administrator Anda.</p>
        </div>
    </div>

    <div class="max-w-4xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Sidebar Info -->
            <div class="space-y-6">
                <div
                    class="bg-gray-900 text-white rounded-3xl p-8 relative overflow-hidden shadow-xl shadow-gray-900/20">
                    <div class="absolute top-0 right-0 p-4 opacity-10">
                        <i class="fas fa-user-shield text-8xl"></i>
                    </div>
                    <div class="relative z-10 text-center">
                        <div
                            class="w-24 h-24 bg-primary-500/20 border-4 border-primary-500/30 rounded-full flex items-center justify-center mx-auto mb-4">
                            <span class="text-4xl font-black text-white">
                                <%= user.name.charAt(0) %>
                            </span>
                        </div>
                        <h2 class="text-xl font-bold">
                            <%= user.name %>
                        </h2>
                        <p class="text-gray-400 text-sm">@<%= user.username %>
                        </p>
                        <div
                            class="mt-6 inline-flex items-center px-3 py-1 bg-emerald-500/20 text-emerald-400 text-[10px] font-bold uppercase tracking-widest rounded-full">
                            Administrator
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-3xl p-8 border border-gray-100 shadow-sm">
                    <h3 class="font-bold text-gray-900 mb-4 flex items-center gap-2">
                        <i class="fas fa-info-circle text-primary-500"></i>
                        Pusat Keamanan
                    </h3>
                    <ul class="space-y-4 text-sm text-gray-500 leading-relaxed">
                        <li>Gunakan kombinasi password yang kuat untuk menghindari akses tidak sah.</li>
                        <li>Username digunakan untuk login ke panel admin.</li>
                        <li>Perubahan profil akan langsung berlaku pada sesi ini.</li>
                    </ul>
                </div>
            </div>

            <!-- Form Card -->
            <div class="lg:col-span-2">
                <form action="/profile" method="POST"
                    class="bg-white rounded-3xl shadow-xl border border-gray-100 overflow-hidden">
                    <% if (success) { %>
                        <div
                            class="p-6 bg-emerald-50 border-b border-emerald-100 text-emerald-600 font-bold flex items-center gap-3">
                            <i class="fas fa-check-circle text-xl"></i>
                            <%= success %>
                        </div>
                        <% } %>
                            <% if (error) { %>
                                <div
                                    class="p-6 bg-rose-50 border-b border-rose-100 text-rose-600 font-bold flex items-center gap-3">
                                    <i class="fas fa-exclamation-circle text-xl"></i>
                                    <%= error %>
                                </div>
                                <% } %>

                                    <div class="p-8 lg:p-10 space-y-8">
                                        <div>
                                            <h3
                                                class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-6 border-b border-gray-50 pb-2">
                                                Informasi Dasar</h3>
                                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                                <div class="space-y-2">
                                                    <label for="name"
                                                        class="text-xs font-bold text-gray-500 uppercase px-1">Nama
                                                        Lengkap</label>
                                                    <input type="text" id="name" name="name" value="<%= user.name %>"
                                                        required
                                                        class="w-full px-5 py-4 bg-gray-50 border border-transparent focus:border-primary-500 focus:bg-white rounded-2xl outline-none transition-all font-medium text-gray-900">
                                                </div>
                                                <div class="space-y-2">
                                                    <label for="username"
                                                        class="text-xs font-bold text-gray-500 uppercase px-1">Username
                                                        Login</label>
                                                    <input type="text" id="username" name="username"
                                                        value="<%= user.username %>" required
                                                        class="w-full px-5 py-4 bg-gray-50 border border-transparent focus:border-primary-500 focus:bg-white rounded-2xl outline-none transition-all font-medium text-gray-900">
                                                </div>
                                            </div>
                                        </div>

                                        <div>
                                            <h3
                                                class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-6 border-b border-gray-50 pb-2">
                                                Keamanan & Password</h3>
                                            <div class="space-y-6">
                                                <div class="space-y-2">
                                                    <label for="current_password"
                                                        class="text-xs font-bold text-gray-500 uppercase px-1">Password
                                                        Saat Ini (Konfirmasi) *</label>
                                                    <input type="password" id="current_password" name="current_password"
                                                        required placeholder="••••••••"
                                                        class="w-full px-5 py-4 bg-gray-50 border border-transparent focus:border-primary-500 focus:bg-white rounded-2xl outline-none transition-all font-medium text-gray-900">
                                                </div>
                                                <div class="space-y-2">
                                                    <label for="new_password"
                                                        class="text-xs font-bold text-gray-500 uppercase px-1">Password
                                                        Baru (Opsional)</label>
                                                    <input type="password" id="new_password" name="new_password"
                                                        placeholder="Biarkan kosong jika tidak diubah"
                                                        class="w-full px-5 py-4 bg-gray-50 border border-transparent focus:border-primary-500 focus:bg-white rounded-2xl outline-none transition-all font-medium text-gray-900">
                                                    <p class="text-[10px] text-gray-400 mt-1 px-1">Minimal 8 karakter
                                                        dengan kombinasi angka dan huruf.</p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="p-8 bg-gray-50/50 border-t border-gray-100 flex justify-end">
                                        <button type="submit"
                                            class="px-10 py-4 bg-primary-600 text-white font-extrabold rounded-2xl hover:bg-primary-700 transition-all shadow-xl shadow-primary-500/20">
                                            Simpan Perubahan
                                        </button>
                                    </div>
                </form>
            </div>
        </div>
    </div>
</div>